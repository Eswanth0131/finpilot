generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  createdAt DateTime @default(now())

  accounts     Account[]
  vendors      Vendor[]
  transactions Transaction[]
  alerts       Alert[]
  forecasts    Forecast[]
  portfolios   Portfolio[]
  agentRuns    AgentRun[]
}

model Account {
  id             String @id @default(cuid())
  organizationId String
  name           String
  type           String
  balance        Float

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  category       String
  riskLevel      String   @default("low")
  recurring      Boolean  @default(false)
  firstSeenAt    DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id             String   @id @default(cuid())
  organizationId String
  accountId      String
  vendorId       String?
  date           DateTime
  description    String
  category       String
  amount         Float
  direction      String
  anomalyScore   Float    @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])
  vendor       Vendor?      @relation(fields: [vendorId], references: [id])
  alerts       Alert[]
}

model Forecast {
  id                   String   @id @default(cuid())
  organizationId        String
  scenario             String
  monthlyBurn           Float
  revenueGrowth         Float
  projectedRunwayMonths Float
  createdAt             DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}

model Portfolio {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  holdings     Holding[]
}

model Holding {
  id                String @id @default(cuid())
  portfolioId       String
  ticker            String
  assetType         String
  sector            String
  allocationPercent Float
  currentValue      Float

  portfolio Portfolio @relation(fields: [portfolioId], references: [id])
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  transactionId  String?
  alertType      String
  severity       String
  title          String
  explanation    String
  status         String   @default("open")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  transaction  Transaction? @relation(fields: [transactionId], references: [id])
}

model AgentRun {
  id             String   @id @default(cuid())
  organizationId String
  userQuery      String
  answer         String
  confidence     Float
  recordsUsed    Json
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
}